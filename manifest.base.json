{
  "name": "Priority Tab Modern",
  "description": "A customizable new tab page for tracking priorities, progress, colors, backgrounds, and fluid animation.",
  "version": "1.0.0",
  "manifest_version": 3,
  "homepage_url": "https://github.com/DimiK1337/Priority-Tab-Modern#readme",
  "chrome_url_overrides": {
    "newtab": "prioritab.html"
  },
  "permissions": [
    "storage",
    "unlimitedStorage",
    "management"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "priority-tab-modern@dimik1337.dev",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "icons": {
    "16": "assets/logo/priority_tab_modern_logo_16.png",
    "32": "assets/logo/priority_tab_modern_logo_32.png",
    "48": "assets/logo/priority_tab_modern_logo_48.png",
    "128": "assets/logo/priority_tab_modern_logo_128.png"
  }
}
